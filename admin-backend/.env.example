# ========== SERVIDOR ==========
PORT=3001
NODE_ENV=development

# ========== AUTENTICACIÓN ==========
# Contraseña simple para el panel admin
ADMIN_PASSWORD=tu-contraseña-super-segura-cambiar-en-produccion
JWT_SECRET=tu-jwt-secret-cambiar-en-produccion

# ========== GITHUB (IMPORTANTE) ==========
# 1. Ir a https://github.com/settings/tokens
# 2. Crear nuevo "Personal access token (classic)"
# 3. Permisos necesarios: repo (read+write), workflow
# 4. Copiar token aquí
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Propietario del repositorio (usuario o organización)
GITHUB_OWNER=tu-usuario-github

# Nombre del repositorio
GITHUB_REPO=landing-marcos-agentes

# Rama donde guardar cambios por defecto
# "staging" para pre-prod, "main" para prod
GITHUB_BRANCH=staging

# Email para commits (aparecerá en GitHub history)
GITHUB_EMAIL=admin@landing-marcos.local

# ========== CORS ==========
# URLs autorizadas para CORS (separadas por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://admin-marcos.vercel.app,https://admin.landing-marcos.com

# ========== UPLOADS ==========
# Tamaño máximo de upload en MB
MAX_UPLOAD_SIZE_MB=50

# ========== LOGGING ==========
LOG_LEVEL=info
